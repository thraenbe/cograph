{
  "name": "cograph",
  "displayName": "CoGraph",
  "description": "Graph-based visualization of Python project call graphs",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Programming Languages"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cograph.visualize",
        "title": "CoGraph: Visualize Project"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "@vscode/test-electron": "^2.3.0",
    "mocha": "^10.4.0",
    "@types/mocha": "^10.0.6",
    "glob": "^10.3.0",
    "sinon": "^17.0.0",
    "@types/sinon": "^17.0.0"
  }
}
